{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "type": "command", "bash": "plugins/cost-guard/adapters/copilot/adapter.sh session-start", "powershell": "plugins/cost-guard/adapters/copilot/adapter.ps1 session-start", "timeoutSec": 10 }
    ],
    "preToolUse": [
      { "type": "command", "bash": "plugins/cost-guard/adapters/copilot/adapter.sh pre-tool", "powershell": "plugins/cost-guard/adapters/copilot/adapter.ps1 pre-tool", "timeoutSec": 5 }
    ],
    "postToolUse": [
      { "type": "command", "bash": "plugins/cost-guard/adapters/copilot/adapter.sh post-tool", "powershell": "plugins/cost-guard/adapters/copilot/adapter.ps1 post-tool", "timeoutSec": 5 }
    ],
    "errorOccurred": [
      { "type": "command", "bash": "plugins/cost-guard/adapters/copilot/adapter.sh error", "powershell": "plugins/cost-guard/adapters/copilot/adapter.ps1 error", "timeoutSec": 5 }
    ],
    "sessionEnd": [
      { "type": "command", "bash": "plugins/cost-guard/adapters/copilot/adapter.sh session-end", "powershell": "plugins/cost-guard/adapters/copilot/adapter.ps1 session-end", "timeoutSec": 15 }
    ]
  }
}
