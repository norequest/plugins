{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT:-.}/adapters/codex/adapter.sh\" session-start", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT:-.}/adapters/codex/adapter.sh\" pre-tool", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT:-.}/adapters/codex/adapter.sh\" post-tool", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT:-.}/adapters/codex/adapter.sh\" session-end", "timeout": 15 }
        ]
      }
    ]
  }
}
