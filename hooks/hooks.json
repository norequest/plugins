{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/plugins/cost-guard/adapters/gemini/adapter.sh\" session-start", "timeout": 10000 }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/plugins/cost-guard/adapters/gemini/adapter.sh\" pre-tool", "timeout": 10000 }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/plugins/cost-guard/adapters/gemini/adapter.sh\" post-tool", "timeout": 10000 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "\"${extensionPath}/plugins/cost-guard/adapters/gemini/adapter.sh\" session-end", "timeout": 15000 }
        ]
      }
    ]
  }
}
